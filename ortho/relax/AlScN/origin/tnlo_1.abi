#Structural optimisation
ngkpt 3 3 2
kptopt 1
nshiftk 1
autoparal 1
shiftk    0.5    0.5    0.5
restartxf -1
chkdilatmx 0
##############################################
####                  STRUCTURE
##############################################
natom 32
 ntypat 3
 typat
 1 2 1
 1 1 1
 1 1 1
 2 1 1
 1 1 1
 1 3 3
 3 3 3
 3 3 3
 3 3 3
 3 3 3
 3 3
 znucl 13 21 7
 xred
