#### 37.5% Fe-doped AlN

#Structural optimisation
ngkpt 3 3 2
kptopt 1
autoparal 1
nshiftk 4
shiftk  0.5 0.5 0.5  # These shifts will be the same for all grids
        0.5 0.0 0.0
        0.0 0.5 0.0
        0.0 0.0 0.5
restartxf -1
chkdilatmx 0

#Miscellaneous
 prtwf 0  prtden 0  prteig 0

#The following parameter is present for testing purposes only;
#It forces the use of linear algebra on the GPU.
gpu_option 2
istwfk *1
fftalg 401
wfoptalg 114
bandpp 1

nspden 2 # (Collinear)
nsppol 2 # (FM)
nspinor 1 # no spinorial WF
spinat
